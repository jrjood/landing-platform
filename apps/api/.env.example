# API Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development
PUBLIC_SITE_URL=https://wealthholding-eg.com

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=landing_platform

# JWT — generate a strong secret for production: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Admin (for seeding)
ADMIN_EMAIL=admin@landingplatform.com
ADMIN_PASSWORD=Admin@123456

# CORS — comma-separated list of allowed origins
# For production: restrict to your actual domains only
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://wealthholding-eg.com,https://citra.wealthholding-eg.com
CORS_ROOT_DOMAIN=wealthholding-eg.com
